generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int       @id @default(autoincrement())
  username    String    @unique // L'identifiant de connexion
  pseudo      String?   // Le nom qui sera affiché sur l'app (ex: "Elouand du 34")
  password    String
  email       String?   @unique // Ajout de l'unicité pour l'email
  profileUrl  String?
  photos      Photo[]
  groups      Group[]   @relation("UserGroups")
  comments    Comment[]
  likes       Like[]
}

model Photo {
  id              Int      @id @default(autoincrement())
  url             String   // URL de l'image
  audioUrl        String?  // URL du fichier audio (note vocale) [cite: 19, 27]
  description     String?
  type_lieu       String   // ex: "nature", "musee" [cite: 16, 32]
  latitude        Float
  longitude       Float
  date            DateTime @default(now())
  
  // Gestion de la visibilité [cite: 18, 26]
  is_public       Boolean  @default(true)
  groupId         Int?     // Si null et is_public=false, c'est privé [cite: 39]
  group           Group?   @relation(fields: [groupId], references: [id])
  
  author          User?    @relation(fields: [authorId], references: [id])
  authorId        Int?
  comments    Comment[] // Relation : une photo peut avoir plusieurs commentaires
  osmId       BigInt?  // L'ID unique provenant d'OpenStreetMap
  placeName   String?  // Le nom officiel renvoyé par l'API (ex: "Jardins du Trocadéro")
  likesCount Int     @default(0) // On renomme pour plus de clarté
  likedBy    Like[]    // Relation : les likes reçus par cette photo
  // Les tags restent utiles pour le filtrage par ambiance (ex: "Randonnée")
}
model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())
  
  // L'auteur du commentaire
  author    User     @relation(fields: [authorId], references: [id])
  authorId  Int
  
  // La photo concernée
  photo     Photo    @relation(fields: [photoId], references: [id])
  photoId   Int
}
model Group {
  id      Int      @id @default(autoincrement())
  name    String
  users   User[]   @relation("UserGroups")
  photos  Photo[]  // Les photos réservées à ce groupe [cite: 18, 39]
}
model Like {
  id      Int    @id @default(autoincrement())
  user    User   @relation(fields: [userId], references: [id])
  userId  Int
  photo   Photo  @relation(fields: [photoId], references: [id])
  photoId Int

  // ⚠️ CETTE LIGNE EST LA CLÉ :
  // Elle interdit d'avoir deux fois le même couple userId/photoId
  @@unique([userId, photoId]) 
}
model PointOfInterest {
  id          Int      @id @default(autoincrement())
  name        String
  category    String   // restauration, loisirs, culture [cite: 51]
  latitude    Float
  longitude   Float
  budget_est  Float
  effort_lvl  Int      // 1 à 5 (enfants, seniors) [cite: 52]
}

